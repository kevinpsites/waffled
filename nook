#!/usr/bin/env bash
# nook — one-touch control for the local stack (postgres, api, powersync, caddy).
#
#   ./nook up        start everything (creates .env on first run, builds images,
#                    runs migrations via the one-shot migrate service), then status
#   ./nook status    show each container's state + health (✓/✗)
#   ./nook down      stop & remove the stack
#   ./nook restart [svc]   restart all (or one) service
#   ./nook rebuild [svc]   force a rebuild + recreate (all, or one)
#   ./nook logs [svc]      follow logs (all, or one)
#   ./nook migrate   re-apply DB migrations from the host (also run automatically on up)
#   ./nook backup [list]   run a DB backup now (or list existing dumps)
#   ./nook restore <file>  restore a dump (DESTRUCTIVE — stops the app, overwrites the DB)
#   ./nook psql      open a psql shell on the database
#   ./nook token [sub]     mint a dev JWT for localStorage (default sub: dev|demo)
#   ./nook doctor    deep health check (db, migrations, jobs, calendar, storage, backup)
#   ./nook admin [cmd]     operator/break-glass commands (reset-password, list-members,
#                    make-admin, prune-sessions, …); run './nook admin help' for the list
#   ./nook observability up|down   run a local Grafana/OTEL stack + point the api at it
#   ./nook web       run the Vite dev server (HMR) on :5175
#
# Everything is driven off infra/compose so you never type the long flags.
set -euo pipefail

# Resolve repo root from this script's location, so it works from anywhere.
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$ROOT/infra/compose/docker-compose.yml"
ENV_FILE="$ROOT/infra/compose/.env"
DC=(docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE")

# Services we expect to be running, in startup order.
SERVICES=(postgres api powersync caddy backup)

c_reset=$'\033[0m'; c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'; c_dim=$'\033[2m'

# Read one KEY=value from .env without sourcing it (the file has values with
# spaces, e.g. GOOGLE_CALENDAR_SCOPES, which `source` chokes on).
env_val() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2- || true; }

# Set (or append) KEY=value in .env. '|' is a safe sed delimiter (no '|' in URLs/secrets here).
set_env_var() {
  if grep -qE "^$1=" "$ENV_FILE" 2>/dev/null; then
    sed -i.bak -E "s|^$1=.*$|$1=$2|" "$ENV_FILE" && rm -f "$ENV_FILE.bak"
  else
    echo "$1=$2" >> "$ENV_FILE"
  fi
}

# Build provenance for the api image — stamped into /healthz + /api/health.
export_build_meta() {
  GIT_SHA="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo dev)"
  BUILD_TIME="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  export GIT_SHA BUILD_TIME
}

# First-run bootstrap: if there's no .env, copy the example and fill the required
# secrets with freshly generated values so `./nook up` works on a clean clone with
# zero manual editing. Existing .env files are never touched.
ensure_env() {
  [ -f "$ENV_FILE" ] && return 0
  echo "${c_dim}No infra/compose/.env — creating it from .env.example…${c_reset}"
  cp "$ROOT/infra/compose/.env.example" "$ENV_FILE"
  if command -v openssl >/dev/null 2>&1; then
    # base64 chars are [A-Za-z0-9+/=] (no '|'), so '|' is a safe sed delimiter.
    secret_set() { sed -i.bak -E "s|^$1=.*$|$1=$2|" "$ENV_FILE" && rm -f "$ENV_FILE.bak"; }
    secret_set LOCAL_JWT_SECRET     "$(openssl rand -base64 48 | tr -d '\n')"
    secret_set TOKEN_ENCRYPTION_KEY "$(openssl rand -base64 32 | tr -d '\n')"
    secret_set POSTGRES_PASSWORD    "$(openssl rand -base64 24 | tr -d '\n')"
    echo "${c_grn}Created $ENV_FILE with generated secrets.${c_reset}"
  else
    echo "${c_ylw}openssl not found — set LOCAL_JWT_SECRET, TOKEN_ENCRYPTION_KEY, and"
    echo "POSTGRES_PASSWORD in $ENV_FILE before relying on OIDC/Google or production.${c_reset}"
  fi
}

status() {
  local any_fail=0
  printf '%-12s %-10s %s\n' "SERVICE" "STATE" "HEALTH"
  printf '%s\n' "$c_dim--------------------------------------$c_reset"
  for s in "${SERVICES[@]}"; do
    local cid state health mark color
    cid="$("${DC[@]}" ps -q "$s" 2>/dev/null || true)"
    if [ -z "$cid" ]; then
      printf '%s✗ %-10s %-10s %s%s\n' "$c_red" "$s" "missing" "not running" "$c_reset"
      any_fail=1; continue
    fi
    state="$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || echo unknown)"
    health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}—{{end}}' "$cid" 2>/dev/null || echo —)"
    if [ "$state" = "running" ] && { [ "$health" = "healthy" ] || [ "$health" = "—" ]; }; then
      color="$c_grn"; mark="✓"
    else
      color="$c_red"; mark="✗"; any_fail=1
    fi
    printf '%s%s %-10s %-10s %s%s\n' "$color" "$mark" "$s" "$state" "$health" "$c_reset"
  done
  [ "$any_fail" -eq 0 ] && echo "${c_grn}All services healthy.${c_reset}" \
                        || echo "${c_ylw}Some services are not healthy — see 'nook logs <svc>'.${c_reset}"
  return "$any_fail"
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  up)
    ensure_env; export_build_meta
    echo "${c_dim}Starting stack (building as needed, applying migrations)…${c_reset}"
    "${DC[@]}" up -d --build "$@"
    echo; status || true
    ;;
  down)    "${DC[@]}" down "$@" ;;
  restart) "${DC[@]}" restart "$@"; echo; status || true ;;
  rebuild) ensure_env; export_build_meta; "${DC[@]}" up -d --build --force-recreate "$@"; echo; status || true ;;
  logs)    "${DC[@]}" logs -f --tail=120 "$@" ;;
  status|st|ps) status || true ;;
  migrate)
    pg_user="$(env_val POSTGRES_USER)"; pg_pass="$(env_val POSTGRES_PASSWORD)"
    pg_db="$(env_val POSTGRES_DB)"; pg_port="$(env_val POSTGRES_PORT)"; pg_port="${pg_port:-5432}"
    echo "${c_dim}Applying migrations…${c_reset}"
    ( cd "$ROOT/apps/api" && DATABASE_URL="postgres://$pg_user:$pg_pass@localhost:$pg_port/$pg_db" npm run migrate )
    ;;
  backup)
    # Run a backup right now (or list dumps) via the backup sidecar. It has pg_dump,
    # the /backups target, and DATABASE_URL already — no flags to remember.
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^nook-backup$'; then
      echo "${c_red}nook-backup is not running — start it with ./nook up${c_reset}"; exit 2
    fi
    if [ "${1:-}" = "list" ]; then
      docker exec nook-backup sh -c 'ls -lh /backups/nook-*.sql.gz 2>/dev/null || echo "no backups yet"'
    else
      echo "${c_dim}Running a backup now…${c_reset}"
      docker exec nook-backup nook-backup
    fi
    ;;
  restore)
    file="${1:-}"
    if [ -z "$file" ]; then
      echo "usage: ./nook restore <file>   (see ./nook backup list for names, e.g. nook-20260701-020000.sql.gz)"; exit 1
    fi
    file="$(basename "$file")"   # accept a bare name or a path; the file lives in /backups
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^nook-backup$'; then
      echo "${c_red}nook-backup is not running — start it with ./nook up${c_reset}"; exit 2
    fi
    if ! docker exec nook-backup test -f "/backups/$file"; then
      echo "${c_red}/backups/$file not found. Run './nook backup list'.${c_reset}"; exit 1
    fi
    echo "${c_ylw}This OVERWRITES the current database with $file — all current data is replaced.${c_reset}"
    if [ -t 0 ]; then
      read -r -p "Type 'restore' to continue: " ans
      [ "$ans" = "restore" ] || { echo "aborted"; exit 1; }
    fi
    echo "${c_dim}Stopping app services (api, powersync, caddy) so nothing writes during the restore…${c_reset}"
    "${DC[@]}" stop api powersync caddy || true
    echo "${c_dim}Restoring…${c_reset}"
    # Plain-SQL dump: the --clean/--if-exists header drops+recreates objects, so piping
    # it back through psql restores in place. --single-transaction → all-or-nothing.
    docker exec nook-backup sh -c \
      "gunzip -c /backups/$file | psql \"\$DATABASE_URL\" -v ON_ERROR_STOP=1 --single-transaction"
    echo "${c_dim}Restarting the stack (migrations re-run to catch up an older dump)…${c_reset}"
    export_build_meta; "${DC[@]}" up -d
    echo; status || true
    echo "${c_grn}Restore complete.${c_reset}"
    ;;
  psql)
    docker exec -it nook-postgres psql -U "$(env_val POSTGRES_USER)" -d "$(env_val POSTGRES_DB)" ;;
  token)
    sub="${1:-dev|demo}"
    docker exec nook-api node dist/mint-token.js --sub "$sub" ;;
  doctor)
    # Deep health from inside the api container (no token/HTTP needed), then the
    # container-health table. Non-zero exit if anything is degraded/down.
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^nook-api$'; then
      echo "${c_red}nook-api is not running — start it with ./nook up${c_reset}"; exit 2
    fi
    hc=0; docker exec nook-api node dist/health-cli.js --pretty || hc=$?
    echo
    sc=0; status || sc=$?
    [ "$hc" -gt "$sc" ] && exit "$hc" || exit "$sc"
    ;;
  admin)
    # Operator/break-glass commands, run inside the api container (reaches the DB +
    # encryption key directly — no token/HTTP). Allocate a TTY when we have one so the
    # destructive-command confirmation prompts work.
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^nook-api$'; then
      echo "${c_red}nook-api is not running — start it with ./nook up${c_reset}"; exit 2
    fi
    if [ -t 0 ]; then ti=(-it); else ti=(-i); fi
    docker exec "${ti[@]}" nook-api node dist/admin.js "$@"
    ;;
  observability)
    ensure_env
    case "${1:-}" in
      up)
        set_env_var OTEL_EXPORTER_OTLP_ENDPOINT "http://lgtm:4318"
        echo "${c_dim}Starting local Grafana/OTEL stack + restarting api…${c_reset}"
        OTEL_EXPORTER_OTLP_ENDPOINT="http://lgtm:4318" "${DC[@]}" --profile observability up -d lgtm
        "${DC[@]}" up -d api
        gport="$(env_val GRAFANA_PORT)"; gport="${gport:-3001}"
        echo "${c_grn}Observability ON. Grafana → http://localhost:$gport (login admin / admin)${c_reset}"
        ;;
      down)
        set_env_var OTEL_EXPORTER_OTLP_ENDPOINT ""
        "${DC[@]}" --profile observability stop lgtm || true
        "${DC[@]}" up -d api
        echo "${c_grn}Observability OFF (api restarted without an OTLP endpoint; lgtm stopped).${c_reset}"
        ;;
      *) echo "usage: ./nook observability up|down"; exit 1 ;;
    esac
    ;;
  web)
    # Vite dev server with HMR on :5173 (separate from the stack's :8080 build).
    ( cd "$ROOT/apps/web" && npm run dev ) ;;
  help|-h|--help|*)
    awk 'NR>1 && /^#/ {sub(/^# ?/, ""); print; next} NR>1 {exit}' "$ROOT/nook" ;;
esac
