# secrets — never commit
.env
.env.*
!.env.example
*.tfvars
!*.example.tfvars
secrets/
*.p8
*.pem
*-key.json

# terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# node
# No trailing slash: also ignore a `node_modules` *symlink* (worktrees symlink
# deps in), so it can never be committed as a tracked link again — see PR #51.
node_modules
dist/
build/
*.tsbuildinfo

# astro generated cache/types (website/.astro) — regenerated on dev/build
.astro/
*.log
.DS_Store

# ios
ios/**/xcuserdata/
ios/**/*.xcuserstate
ios/**/DerivedData/

# docker
postgres/data/

# claude code agent workspace (local only)
.claude/
