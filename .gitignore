# secrets — never commit
.env
.env.*
!.env.example
*.tfvars
!*.example.tfvars
secrets/
*.p8
*.pem
*-key.json

# terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# local compose overrides (e.g. the OCI cloud deploy) — deployment-local, not committed
infra/compose/docker-compose.override.yml
infra/compose/caddy/Caddyfile.oci

# node
node_modules/
dist/
build/
*.tsbuildinfo

# astro generated cache/types (website/.astro) — regenerated on dev/build
.astro/
*.log
.DS_Store

# ios
ios/**/xcuserdata/
ios/**/*.xcuserstate
ios/**/DerivedData/

# docker
postgres/data/

# claude code agent workspace (local only)
.claude/
