#!/usr/bin/env bash
# waffled — one-touch control for the local stack (postgres, api, powersync, caddy).
#
#   ./waffled up        start everything (checks prereqs, creates .env on first run, PULLS
#                    the published images, runs migrations), then status + what's-next
#   ./waffled up --build   same, but build the images from source (dev / bleeding-edge)
#   ./waffled upgrade [--skip-backup]   pull the latest release: fast-forward the repo,
#                    back up the DB, bump the pinned version, and apply migrations
#   ./waffled setup     guided: how devices reach this server (localhost / LAN IP / hostname)
#   ./waffled status    show each container's state + health (✓/✗)
#   ./waffled down      stop & remove the stack
#   ./waffled restart [svc]   restart all (or one) service
#   ./waffled rebuild [svc]   force a rebuild + recreate (all, or one)
#   ./waffled logs [svc]      follow logs (all, or one)
#   ./waffled migrate   re-apply DB migrations from the host (also run automatically on up)
#   ./waffled backup [list|verify [file]]   run, list, or safely test DB backups
#   ./waffled restore <file>  restore a dump (DESTRUCTIVE — stops the app, overwrites the DB)
#   ./waffled psql      open a psql shell on the database
#   ./waffled token [sub]     mint a dev JWT for localStorage (default sub: dev|demo)
#   ./waffled doctor    deep health check (db, migrations, jobs, calendar, storage, backup)
#   ./waffled admin [cmd]     operator/break-glass commands (reset-password, list-members,
#                    make-admin, prune-sessions, …); run './waffled admin help' for the list
#   ./waffled observability up|down   run a local Grafana/OTEL stack + point the api at it
#   ./waffled web       run the Vite dev server (HMR) on :5175
#   ./waffled release X.Y.Z   bump every version site (api, web, compose, iOS) in one
#                    commit + tag vX.Y.Z; run locally so the tag triggers CI (no PAT)
#
# Everything is driven off infra/compose so you never type the long flags.
set -euo pipefail

# Resolve repo root from this script's location, so it works from anywhere.
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$ROOT/infra/compose/docker-compose.yml"
ENV_FILE="$ROOT/infra/compose/.env"

# Optional compose overrides, layered on top of the base file so a deployment can add
# published ports / mounts without editing tracked files (e.g. the OCI cloud deploy).
# Opt-in ONLY via explicit `--override <file>` flags (parsed just below) — nothing is
# auto-loaded, so normal installs are never affected.
COMPOSE_OVERRIDES=()

# Services we expect to be running, in startup order.
SERVICES=(postgres api powersync caddy backup)

c_reset=$'\033[0m'; c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'; c_dim=$'\033[2m'

# Read one KEY=value from .env without sourcing it (the file has values with
# spaces, e.g. GOOGLE_CALENDAR_SCOPES, which `source` chokes on).
env_val() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2- || true; }

# Set (or append) KEY=value in .env. '|' is a safe sed delimiter (no '|' in URLs/secrets here).
set_env_var() {
  if grep -qE "^$1=" "$ENV_FILE" 2>/dev/null; then
    sed -i.bak -E "s|^$1=.*$|$1=$2|" "$ENV_FILE" && rm -f "$ENV_FILE.bak"
  else
    echo "$1=$2" >> "$ENV_FILE"
  fi
}

# Build provenance for the api image — stamped into /healthz + /api/health.
export_build_meta() {
  GIT_SHA="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo dev)"
  BUILD_TIME="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  export GIT_SHA BUILD_TIME
}

# Bootstrap required secrets on a clean clone and fill values added by newer releases.
# Existing non-empty custom values are never changed.
ensure_env() {
  local created=0 postgres_password
  if [ ! -f "$ENV_FILE" ]; then
    echo "${c_dim}No infra/compose/.env — creating it from .env.example…${c_reset}"
    cp "$ROOT/infra/compose/.env.example" "$ENV_FILE"
    created=1
  fi

  if command -v openssl >/dev/null 2>&1; then
    # POSTGRES_PASSWORD is interpolated into postgres:// URLs in docker-compose.yml, so it
    # must be URL-safe: base64 can include '/', which breaks Node's URL parser and fails
    # the one-shot migrate on a fresh install — so generate it as hex, not base64.
    [ -n "$(env_val LOCAL_JWT_SECRET)" ] || set_env_var LOCAL_JWT_SECRET "$(openssl rand -base64 48 | tr -d '\n')"
    [ -n "$(env_val TOKEN_ENCRYPTION_KEY)" ] || set_env_var TOKEN_ENCRYPTION_KEY "$(openssl rand -base64 32 | tr -d '\n')"
    [ -n "$(env_val POWERSYNC_JWT_PRIVATE_KEY)" ] || set_env_var POWERSYNC_JWT_PRIVATE_KEY "$(openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 2>/dev/null | openssl base64 -A)"
    postgres_password="$(env_val POSTGRES_PASSWORD)"
    if [ -z "$postgres_password" ] || { [ "$created" -eq 1 ] && [ "$postgres_password" = "change-me" ]; }; then
      set_env_var POSTGRES_PASSWORD "$(openssl rand -hex 24 | tr -d '\n')"
    fi
  fi

  for secret in LOCAL_JWT_SECRET TOKEN_ENCRYPTION_KEY POSTGRES_PASSWORD POWERSYNC_JWT_PRIVATE_KEY; do
    if [ -z "$(env_val "$secret")" ]; then
      echo "${c_red}✗ $secret is missing in $ENV_FILE.${c_reset} Install openssl or set it manually, then retry."
      return 1
    fi
  done
  if [ "$(env_val LOCAL_JWT_SECRET)" = "waffled-local-dev-secret-change-me" ]; then
    echo "${c_red}✗ LOCAL_JWT_SECRET still uses the public development value.${c_reset} Replace it in $ENV_FILE."
    return 1
  fi
  if [ "$(env_val POSTGRES_PASSWORD)" = "change-me" ]; then
    echo "${c_red}✗ POSTGRES_PASSWORD still uses the example placeholder.${c_reset}"
    echo "Set a URL-safe password in $ENV_FILE. For an existing database, rotate the database user's password first."
    return 1
  fi
  [ "$created" -eq 0 ] || echo "${c_grn}Created $ENV_FILE with generated secrets.${c_reset}"
}

# Upgrade bridge for installs created before PowerSync moved behind Caddy. It also
# keeps Caddy's WebSocket CSP source in sync with the public HTTP(S) endpoint.
sync_powersync_ws_env() {
  local public_url
  public_url="$(env_val POWERSYNC_PUBLIC_URL)"
  public_url="${public_url:-http://localhost:8090}"
  case "$public_url" in
    https://*) set_env_var POWERSYNC_WS_URL "wss://${public_url#https://}" ;;
    http://*) set_env_var POWERSYNC_WS_URL "ws://${public_url#http://}" ;;
    *)
      echo "${c_red}✗ POWERSYNC_PUBLIC_URL must start with http:// or https://.${c_reset}"
      return 1
      ;;
  esac
}

ensure_powersync_proxy_env() {
  local site host
  if [ -z "$(env_val POWERSYNC_CADDY_ADDRESS)" ]; then
    site="$(env_val CADDY_SITE_ADDRESS)"
    case "$site" in
      ""|:*) set_env_var POWERSYNC_CADDY_ADDRESS ":8090" ;;
      *)
        host="${site#https://}"; host="${host#http://}"; host="${host%%:*}"
        set_env_var POWERSYNC_CADDY_ADDRESS "https://$host:8090"
        ;;
    esac
  fi

  sync_powersync_ws_env
}

# Return a replacement only for the exact legacy localhost default. Custom OAuth
# callbacks belong to the operator because changing one also requires updating the
# Google Cloud console; those are warned about below, never silently overwritten.
google_callback_replacement() {
  local current="$1" public_base="$2" http_port="$3"
  [ "$current" = "http://localhost:3000/auth/google/calendar/callback" ] || return 1
  if [ -n "$public_base" ]; then
    printf '%s/auth/google/calendar/callback' "${public_base%/}"
  else
    printf 'http://localhost:%s/auth/google/calendar/callback' "$http_port"
  fi
}

ensure_google_callback_env() {
  local current public_base http_port replacement
  current="$(env_val GOOGLE_CALENDAR_REDIRECT_URI)"
  [ -n "$current" ] || return 0
  public_base="$(env_val PUBLIC_BASE_URL)"
  http_port="$(env_val HTTP_PORT)"; http_port="${http_port:-8080}"
  if replacement="$(google_callback_replacement "$current" "$public_base" "$http_port")"; then
    set_env_var GOOGLE_CALENDAR_REDIRECT_URI "$replacement"
    echo "${c_grn}Updated Google Calendar callback to Caddy: $replacement${c_reset}"
    [ -z "$public_base" ] || echo "${c_ylw}Register this exact callback in Google Cloud before reconnecting Calendar.${c_reset}"
    return 0
  fi
  case "$current" in
    http://*:3000/auth/google/calendar/callback|https://*:3000/auth/google/calendar/callback)
      echo "${c_ylw}Google Calendar callback still targets direct API port :3000, which is now loopback-only.${c_reset}"
      echo "${c_ylw}Set GOOGLE_CALENDAR_REDIRECT_URI to your Caddy origin + /auth/google/calendar/callback and register that exact URL in Google Cloud.${c_reset}"
      ;;
  esac
}

status() {
  local any_fail=0
  printf '%-12s %-10s %s\n' "SERVICE" "STATE" "HEALTH"
  printf '%s\n' "$c_dim--------------------------------------$c_reset"
  for s in "${SERVICES[@]}"; do
    local cid state health mark color
    cid="$("${DC[@]}" ps -q "$s" 2>/dev/null || true)"
    if [ -z "$cid" ]; then
      printf '%s✗ %-10s %-10s %s%s\n' "$c_red" "$s" "missing" "not running" "$c_reset"
      any_fail=1; continue
    fi
    state="$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || echo unknown)"
    health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}—{{end}}' "$cid" 2>/dev/null || echo —)"
    if [ "$state" = "running" ] && { [ "$health" = "healthy" ] || [ "$health" = "—" ]; }; then
      color="$c_grn"; mark="✓"
    else
      color="$c_red"; mark="✗"; any_fail=1
    fi
    printf '%s%s %-10s %-10s %s%s\n' "$color" "$mark" "$s" "$state" "$health" "$c_reset"
  done
  [ "$any_fail" -eq 0 ] && echo "${c_grn}All services healthy.${c_reset}" \
                        || echo "${c_ylw}Some services are not healthy — see 'waffled logs <svc>'.${c_reset}"
  return "$any_fail"
}

services_ready() {
  local targets=("$@")
  [ "${#targets[@]}" -gt 0 ] || targets=("${SERVICES[@]}")
  for s in "${targets[@]}"; do
    local cid state health
    cid="$("${DC[@]}" ps -q "$s" 2>/dev/null || true)"
    [ -n "$cid" ] || return 1
    state="$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || echo unknown)"
    health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}—{{end}}' "$cid" 2>/dev/null || echo unknown)"
    [ "$state" = "running" ] && { [ "$health" = "healthy" ] || [ "$health" = "—" ]; } || return 1
  done
}

# Compose returns as soon as containers start, several seconds before their health
# checks pass. Wait briefly so first-run users see the settled state, not a false alarm.
wait_for_services() {
  local remaining="${WAFFLED_HEALTH_ATTEMPTS:-30}"
  local targets=() service arg
  # Keep only args that name services (compose flags like --build fall through).
  # Iterate "$@" directly: copying it into a named array and expanding that crashes
  # bash < 4.4 (macOS /bin/bash is 3.2) under set -u when no services were named.
  for service in "${SERVICES[@]}"; do
    for arg in "$@"; do
      if [ "$arg" = "$service" ]; then
        targets+=("$service")
        break
      fi
    done
  done
  [ "${#targets[@]}" -gt 0 ] || targets=("${SERVICES[@]}")
  printf '%s' "${c_dim}Waiting for services to become healthy"
  while [ "$remaining" -gt 0 ]; do
    if services_ready "${targets[@]}"; then
      echo "${c_grn} ready.${c_reset}"
      return 0
    fi
    remaining=$((remaining - 1))
    printf '.'
    sleep 2
  done
  echo
  echo "${c_ylw}Services are taking longer than expected; showing their current state.${c_reset}"
  return 1
}

update_repo_for_upgrade() {
  if ! git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1; then
    return 0
  fi

  local branch
  branch="$(git -C "$ROOT" symbolic-ref --short -q HEAD || true)"
  if [ -z "$branch" ]; then
    echo "${c_ylw}⚠ Detached HEAD — skipping repo update. The checked-out release tag will determine the target version.${c_reset}"
    return 0
  fi

  echo "${c_dim}Updating repo ($branch)…${c_reset}"
  if ! git -C "$ROOT" pull --ff-only; then
    echo "${c_red}✗ Couldn't fast-forward the repo (local changes or diverged history).${c_reset}"
    echo "Resolve the repository state, then re-run './waffled upgrade'. No images were changed."
    return 1
  fi
}

# The upgrade's fast-forward can replace ./waffled while bash is still executing the
# OLD copy — which then drives the NEW tree/compose with old logic. That is exactly
# how upgrading 0.7.0 → 0.8.0 broke: the old ensure_env couldn't backfill the newly
# required secrets, so compose died on "required variable" mid-upgrade. If the script
# changed on disk, hand the rest of the upgrade to the new copy exactly once
# (WAFFLED_UPGRADE_REEXEC breaks the recursion).
script_checksum() { cksum < "$ROOT/waffled"; }
maybe_reexec_upgrade() {
  local before="$1"; shift
  if [ -n "${WAFFLED_UPGRADE_REEXEC:-}" ] || [ "$(script_checksum)" = "$before" ]; then
    return 0
  fi
  echo "${c_dim}./waffled was updated — restarting the upgrade with the new version…${c_reset}"
  WAFFLED_UPGRADE_REEXEC=1 exec "$ROOT/waffled" upgrade "$@"
}

run_pre_upgrade_backup() {
  local skip_backup="$1"
  if [ "$skip_backup" -eq 1 ]; then
    echo "${c_ylw}⚠ Skipping the pre-upgrade database backup because --skip-backup was supplied.${c_reset}"
    return 0
  fi

  if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-backup$'; then
    echo "${c_red}✗ The backup service is not running, so no rollback point can be created.${c_reset}"
    echo "Start the stack and retry, or explicitly accept the risk with './waffled upgrade --skip-backup'."
    return 1
  fi

  echo "${c_dim}Backing up the database first (rollback point)…${c_reset}"
  if ! docker exec waffled-backup waffled-backup; then
    echo "${c_red}✗ Pre-upgrade backup failed; the upgrade has been stopped.${c_reset}"
    echo "Fix the backup error and retry, or explicitly accept the risk with './waffled upgrade --skip-backup'."
    return 1
  fi
}

# Restore a dump into a short-lived, isolated Postgres container. This exercises the
# real gunzip -> psql recovery path without stopping or writing to the live stack.
verify_backup_restore() (
  local file="${1:-}" backup_path image drill_container remaining schema_ok

  if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-backup$'; then
    echo "${c_red}waffled-backup is not running — start it with ./waffled up${c_reset}"
    return 2
  fi

  if [ -z "$file" ]; then
    backup_path="$(docker exec waffled-backup sh -c \
      'ls -1t /backups/waffled-*.sql.gz 2>/dev/null | head -1' || true)"
    if [ -z "$backup_path" ]; then
      echo "${c_red}No database backups found. Run './waffled backup' first.${c_reset}"
      return 1
    fi
    file="$(basename "$backup_path")"
  else
    file="$(basename "$file")"
  fi

  case "$file" in
    waffled-*.sql.gz) ;;
    *)
      echo "${c_red}$file is not a Waffled database dump (expected waffled-*.sql.gz).${c_reset}"
      return 1
      ;;
  esac

  if ! docker exec waffled-backup test -f "/backups/$file"; then
    echo "${c_red}/backups/$file not found. Run './waffled backup list'.${c_reset}"
    return 1
  fi
  if ! docker exec waffled-backup sh -c 'gunzip -t "$1"' sh "/backups/$file"; then
    echo "${c_red}$file is corrupt or is not a readable gzip archive.${c_reset}"
    return 1
  fi

  image="$(docker inspect --format '{{.Config.Image}}' waffled-postgres 2>/dev/null || true)"
  if [ -z "$image" ]; then
    echo "${c_red}The waffled-postgres container was not found — start the stack first.${c_reset}"
    return 2
  fi

  drill_container="waffled-restore-drill-$$-${RANDOM:-0}"
  # Expand the generated name while the local is in scope: bash 3.2 runs an EXIT
  # trap after function locals have been torn down under `set -u`.
  trap "docker rm -f '$drill_container' >/dev/null 2>&1 || true" EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM

  echo "${c_dim}Starting an isolated Postgres restore drill for ${file}…${c_reset}"
  if ! docker run -d --rm \
    --name "$drill_container" \
    --label com.waffled.restore-drill=true \
    -e POSTGRES_USER=waffled_verify \
    -e POSTGRES_PASSWORD=waffled-restore-drill-only \
    -e POSTGRES_DB=waffled_verify \
    "$image" -c wal_level=logical >/dev/null; then
    echo "${c_red}Couldn't start the disposable Postgres container.${c_reset}"
    return 1
  fi

  remaining=30
  while [ "$remaining" -gt 0 ]; do
    # pg_isready can report success before the image's entrypoint has created the
    # requested database. Require a real query against that database instead.
    if docker exec "$drill_container" psql \
      -U waffled_verify -d waffled_verify -Atc 'SELECT 1' >/dev/null 2>&1; then
      break
    fi
    remaining=$((remaining - 1))
    sleep 1
  done
  if [ "$remaining" -eq 0 ]; then
    echo "${c_red}Disposable Postgres did not become ready in 30 seconds.${c_reset}"
    return 1
  fi

  if ! docker exec waffled-backup sh -c 'gunzip -c "$1"' sh "/backups/$file" \
    | docker exec -i "$drill_container" psql \
        -U waffled_verify -d waffled_verify \
        -v ON_ERROR_STOP=1 --single-transaction >/dev/null; then
    echo "${c_red}$file could not be restored cleanly.${c_reset}"
    return 1
  fi

  if ! schema_ok="$(docker exec "$drill_container" psql \
    -U waffled_verify -d waffled_verify -Atc \
    "SELECT to_regclass('public.households') IS NOT NULL;" 2>/dev/null)"; then
    echo "${c_red}The restored database could not be inspected.${c_reset}"
    return 1
  fi
  if [ "$(printf '%s' "$schema_ok" | tr -d '[:space:]')" != "t" ]; then
    echo "${c_red}Restore completed, but the Waffled schema is missing.${c_reset}"
    return 1
  fi

  echo "${c_grn}Backup verified: $file restored cleanly in an isolated database.${c_reset}"
  echo "The live Waffled database was not changed. Uploaded-media archives are checked separately."
)

# Best-effort primary LAN IPv4 (for "reach it from a tablet"). Empty if undetectable.
detect_lan_ip() {
  local ip=""
  if command -v ipconfig >/dev/null 2>&1; then            # macOS
    for ifc in en0 en1 en2 en3; do
      ip="$(ipconfig getifaddr "$ifc" 2>/dev/null || true)"; [ -n "$ip" ] && { echo "$ip"; return; }
    done
  fi
  if command -v ip >/dev/null 2>&1; then                   # Linux
    ip="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1)"
    [ -n "$ip" ] && { echo "$ip"; return; }
  fi
  if command -v hostname >/dev/null 2>&1; then
    ip="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"; [ -n "$ip" ] && { echo "$ip"; return; }
  fi
  echo ""
}

# Preflight for `up`/`rebuild`: hard-fail with a friendly fix on the things that make
# `docker compose` blow up cryptically; warn (don't block) on the softer stuff.
preflight() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "${c_red}✗ Docker isn't installed.${c_reset} Get it: https://docs.docker.com/get-docker/"; return 1
  fi
  if ! docker info >/dev/null 2>&1; then
    echo "${c_red}✗ Docker is installed but the daemon isn't running.${c_reset} Start Docker Desktop (or 'sudo systemctl start docker') and retry."; return 1
  fi
  if ! docker compose version >/dev/null 2>&1; then
    echo "${c_red}✗ 'docker compose' (v2) not found.${c_reset} The legacy 'docker-compose' won't work — install the Compose v2 plugin: https://docs.docker.com/compose/install/"; return 1
  fi
  if ! command -v openssl >/dev/null 2>&1; then
    echo "${c_ylw}⚠ openssl not found — missing secrets can't be auto-generated; set them in infra/compose/.env.${c_reset}"
  fi
  # Port conflicts — only on a cold start (skip if our stack already holds them).
  if command -v lsof >/dev/null 2>&1 && ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-'; then
    for pv in "HTTP_PORT:8080:kiosk" "API_PORT:3000:api" "POWERSYNC_PORT:8090:powersync" "POSTGRES_PORT:5432:postgres"; do
      local var="${pv%%:*}" rest="${pv#*:}" def label port
      def="${rest%%:*}"; label="${rest#*:}"
      port="$(env_val "$var")"; port="${port:-$def}"
      if lsof -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
        echo "${c_ylw}⚠ Port $port ($label) looks busy — set $var in infra/compose/.env if startup fails.${c_reset}"
      fi
    done
  fi
  return 0
}

# "You're up — here's what to do next" printed after `up`. Derives the address to open.
next_steps() {
  local http_port site pbu url
  http_port="$(env_val HTTP_PORT)"; http_port="${http_port:-8080}"
  site="$(env_val CADDY_SITE_ADDRESS)"
  pbu="$(env_val PUBLIC_BASE_URL)"
  if [ -n "$site" ] && [ "$site" != ":80" ]; then
    url="https://${site#:}"                 # hostname mode (Caddy auto-TLS)
  elif [ -n "$pbu" ]; then
    url="$pbu"                              # explicit public origin (e.g. LAN, set by ./waffled setup)
  else
    url="http://localhost:$http_port"
  fi
  echo
  echo "${c_grn}✅ Waffled is up.${c_reset} Open ${c_grn}${url}${c_reset} to finish setup (create your household + admin)."
  if [ "$url" = "http://localhost:$http_port" ]; then
    local ip; ip="$(detect_lan_ip)"
    if [ -n "$ip" ]; then
      echo "   Using it from a tablet/phone on your network? Run ${c_dim}./waffled setup${c_reset} (this machine looks like ${ip})."
    fi
  fi
}

# Pull global `--override <file>` flags out of the args (position-independent) and
# build the final compose invocation once the full override list is known.
_wf_args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --override)   shift; [ -n "${1:-}" ] || { echo "${c_red}✗ --override needs a file path.${c_reset}"; exit 1; }; COMPOSE_OVERRIDES+=("$1") ;;
    --override=*) COMPOSE_OVERRIDES+=("${1#--override=}") ;;
    *)            _wf_args+=("$1") ;;
  esac
  shift
done
set -- ${_wf_args[@]+"${_wf_args[@]}"}

DC=(docker compose -f "$COMPOSE_FILE")
for _ovr in ${COMPOSE_OVERRIDES[@]+"${COMPOSE_OVERRIDES[@]}"}; do DC+=(-f "$_ovr"); done
DC+=(--env-file "$ENV_FILE")
[ ${#COMPOSE_OVERRIDES[@]} -gt 0 ] && echo "${c_dim}Compose override(s): ${COMPOSE_OVERRIDES[*]}${c_reset}" >&2

cmd="${1:-help}"; shift || true
case "$cmd" in
  up)
    preflight || exit 1
    ensure_env; ensure_powersync_proxy_env; ensure_google_callback_env; export_build_meta
    # Default: pull the published images (fast — no local toolchain build) and start.
    # `./waffled up --build [svc]` (dev/bleeding-edge): build the images from source
    # instead, stamping the current git SHA into /healthz + /api/health.
    if [ "${1:-}" = "--build" ]; then
      shift
      echo "${c_dim}Building images from source + starting stack (applying migrations)…${c_reset}"
      "${DC[@]}" up -d --build "$@"
    else
      echo "${c_dim}Pulling published images + starting stack (applying migrations)…${c_reset}"
      "${DC[@]}" pull "$@" || echo "${c_ylw}⚠ Couldn't pull some images — using local/cached copies. Run './waffled up --build' to build from source.${c_reset}"
      "${DC[@]}" up -d "$@"
    fi
    wait_for_services "$@" || true
    echo; status || true
    next_steps
    ;;
  upgrade)
    # One-command upgrade to the latest published release. Closes the gap where an
    # existing .env keeps its old WAFFLED_VERSION (ensure_env only writes .env once),
    # so a plain `up` would re-pull the old image. Steps: fast-forward the repo (the
    # tagged repo + image tag are a matched pair — compose/configs/./waffled must agree
    # with the image), sync WAFFLED_VERSION in .env to this checkout's .env.example,
    # then pull + up (the one-shot `migrate` reruns because the image tag changed).
    skip_backup=0
    for arg in "$@"; do
      case "$arg" in
        --skip-backup) skip_backup=1 ;;
        *) echo "usage: ./waffled upgrade [--skip-backup]"; exit 1 ;;
      esac
    done
    preflight || exit 1
    ensure_env
    ensure_powersync_proxy_env
    ensure_google_callback_env
    script_before="$(script_checksum)"
    update_repo_for_upgrade || exit 1
    # If the update replaced this script, restart the upgrade under the new copy NOW —
    # before the backup/pin/pull — so ensure_env and compose logic match the new tree.
    maybe_reexec_upgrade "$script_before" "$@"
    # Snapshot the DB BEFORE changing the version pin or swapping images.
    # Migrations are forward-only, so a missing rollback point is fatal unless
    # the operator explicitly accepts it.
    run_pre_upgrade_backup "$skip_backup" || exit 1
    target="$(grep -E '^WAFFLED_VERSION=' "$ROOT/infra/compose/.env.example" 2>/dev/null | head -1 | cut -d= -f2- || true)"
    current="$(env_val WAFFLED_VERSION)"
    if [ -z "$target" ]; then
      echo "${c_ylw}⚠ No WAFFLED_VERSION in .env.example — leaving .env unchanged.${c_reset}"
    elif [ "$target" = "$current" ]; then
      echo "${c_grn}Already pinned to ${target}.${c_reset}"
    else
      set_env_var WAFFLED_VERSION "$target"
      echo "${c_grn}WAFFLED_VERSION ${current:-unset} → ${target}${c_reset}"
    fi
    export_build_meta
    echo "${c_dim}Pulling images + restarting stack (applying migrations)…${c_reset}"
    "${DC[@]}" pull || echo "${c_ylw}⚠ Couldn't pull some images — confirm the tag exists on GHCR, or run './waffled up --build' to build from source.${c_reset}"
    "${DC[@]}" up -d
    wait_for_services || true
    echo; status || true
    ;;
  down)    "${DC[@]}" down "$@" ;;
  restart) "${DC[@]}" restart "$@"; wait_for_services "$@" || true; echo; status || true ;;
  rebuild) preflight || exit 1; ensure_env; ensure_powersync_proxy_env; ensure_google_callback_env; export_build_meta; "${DC[@]}" up -d --build --force-recreate "$@"; wait_for_services "$@" || true; echo; status || true ;;
  logs)    "${DC[@]}" logs -f --tail=120 "$@" ;;
  status|st|ps) status || true ;;
  migrate)
    pg_user="$(env_val POSTGRES_USER)"; pg_pass="$(env_val POSTGRES_PASSWORD)"
    pg_db="$(env_val POSTGRES_DB)"; pg_port="$(env_val POSTGRES_PORT)"; pg_port="${pg_port:-5432}"
    echo "${c_dim}Applying migrations…${c_reset}"
    ( cd "$ROOT/apps/api" && DATABASE_URL="postgres://$pg_user:$pg_pass@localhost:$pg_port/$pg_db" npm run migrate )
    ;;
  backup)
    # Run, list, or verify dumps via the backup sidecar. It has pg_dump, the
    # /backups target, and DATABASE_URL already — no flags to remember.
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-backup$'; then
      echo "${c_red}waffled-backup is not running — start it with ./waffled up${c_reset}"; exit 2
    fi
    case "${1:-}" in
      list)
        docker exec waffled-backup sh -c 'ls -lh /backups/waffled-*.sql.gz 2>/dev/null || echo "no backups yet"'
        ;;
      verify)
        verify_backup_restore "${2:-}"
        ;;
      "")
        echo "${c_dim}Running a backup now…${c_reset}"
        docker exec waffled-backup waffled-backup
        ;;
      *)
        echo "usage: ./waffled backup [list|verify [file]]"
        exit 1
        ;;
    esac
    ;;
  restore)
    file="${1:-}"
    if [ -z "$file" ]; then
      echo "usage: ./waffled restore <file>   (see ./waffled backup list for names, e.g. waffled-20260701-020000.sql.gz)"; exit 1
    fi
    file="$(basename "$file")"   # accept a bare name or a path; the file lives in /backups
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-backup$'; then
      echo "${c_red}waffled-backup is not running — start it with ./waffled up${c_reset}"; exit 2
    fi
    if ! docker exec waffled-backup test -f "/backups/$file"; then
      echo "${c_red}/backups/$file not found. Run './waffled backup list'.${c_reset}"; exit 1
    fi
    echo "${c_ylw}This OVERWRITES the current database with $file — all current data is replaced.${c_reset}"
    if [ -t 0 ]; then
      read -r -p "Type 'restore' to continue: " ans
      [ "$ans" = "restore" ] || { echo "aborted"; exit 1; }
    fi
    echo "${c_dim}Stopping app services (api, powersync, caddy) so nothing writes during the restore…${c_reset}"
    "${DC[@]}" stop api powersync caddy || true
    echo "${c_dim}Restoring…${c_reset}"
    # Plain-SQL dump: the --clean/--if-exists header drops+recreates objects, so piping
    # it back through psql restores in place. --single-transaction → all-or-nothing.
    docker exec waffled-backup sh -c \
      "gunzip -c /backups/$file | psql \"\$DATABASE_URL\" -v ON_ERROR_STOP=1 --single-transaction"
    echo "${c_dim}Restarting the stack (migrations re-run to catch up an older dump)…${c_reset}"
    export_build_meta; "${DC[@]}" up -d
    wait_for_services || true
    echo; status || true
    echo "${c_grn}Restore complete.${c_reset}"
    ;;
  setup)
    # Guided setup for the one thing that isn't auto-derivable and silently breaks the
    # tablet/iOS app if wrong: how devices reach this server. (A localhost
    # POWERSYNC_PUBLIC_URL makes every non-local client show "Offline".) Everything else
    # — Google, AI, OIDC — is configured in the app's Settings, not here.
    ensure_env
    if [ ! -t 0 ]; then
      echo "${c_ylw}./waffled setup is interactive — run it in a terminal.${c_reset}"; exit 1
    fi
    http_port="$(env_val HTTP_PORT)"; http_port="${http_port:-8080}"
    ps_port="$(env_val POWERSYNC_PORT)"; ps_port="${ps_port:-8090}"
    ip="$(detect_lan_ip)"
    echo "How will devices (tablets, phones, other computers) reach this Waffled server?"
    echo "  1) Just this computer (localhost)"
    if [ -n "$ip" ]; then
      echo "  2) Other devices on my network      (detected: ${c_grn}$ip${c_reset})"
    else
      echo "  2) Other devices on my network      (you'll enter the IP)"
    fi
    echo "  3) A hostname with automatic HTTPS  (e.g. waffled.example.com)"
    printf "Choose [1/2/3]: "; read -r choice
    case "$choice" in
      1)
        set_env_var PUBLIC_BASE_URL ""
        set_env_var POWERSYNC_PUBLIC_URL "http://localhost:$ps_port"
        set_env_var POWERSYNC_CADDY_ADDRESS ":8090"
        set_env_var CADDY_SITE_ADDRESS ":80"
        echo "${c_grn}Set for localhost.${c_reset} Run ${c_dim}./waffled up${c_reset}, then open http://localhost:$http_port"
        ;;
      2)
        addr="$ip"
        printf "IP address of this machine [%s]: " "${ip:-none}"; read -r entered
        [ -n "$entered" ] && addr="$entered"
        [ -n "$addr" ] || { echo "${c_red}No address given — aborting.${c_reset}"; exit 1; }
        set_env_var PUBLIC_BASE_URL "http://$addr:$http_port"
        set_env_var POWERSYNC_PUBLIC_URL "http://$addr:$ps_port"
        set_env_var POWERSYNC_CADDY_ADDRESS ":8090"
        set_env_var CADDY_SITE_ADDRESS ":80"
        echo "${c_grn}Set for your network ($addr).${c_reset} Run ${c_dim}./waffled up${c_reset}, then open http://$addr:$http_port on any device."
        echo "${c_dim}Tip: reserve a static IP for this machine in your router so the address doesn't drift.${c_reset}"
        ;;
      3)
        printf "Hostname (e.g. waffled.example.com): "; read -r host
        [ -n "$host" ] || { echo "${c_red}No hostname given — aborting.${c_reset}"; exit 1; }
        set_env_var CADDY_SITE_ADDRESS "$host"
        set_env_var PUBLIC_BASE_URL "https://$host"
        set_env_var POWERSYNC_PUBLIC_URL "https://$host:$ps_port"
        set_env_var POWERSYNC_CADDY_ADDRESS "https://$host:8090"
        echo "${c_grn}Set for https://$host.${c_reset} Enable the 443 mapping in infra/compose/docker-compose.yml, point DNS at this machine, then run ${c_dim}./waffled up${c_reset}."
        echo "${c_dim}PowerSync is served through Caddy with TLS on :$ps_port.${c_reset}"
        ;;
      *) echo "${c_red}Unknown choice — run ./waffled setup again.${c_reset}"; exit 1 ;;
    esac
    sync_powersync_ws_env
    ;;
  psql)
    docker exec -it waffled-postgres psql -U "$(env_val POSTGRES_USER)" -d "$(env_val POSTGRES_DB)" ;;
  token)
    sub="${1:-dev|demo}"
    docker exec waffled-api node dist/mint-token.js --sub "$sub" ;;
  doctor)
    # Deep health from inside the api container (no token/HTTP needed), then the
    # container-health table. Non-zero exit if anything is degraded/down.
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-api$'; then
      echo "${c_red}waffled-api is not running — start it with ./waffled up${c_reset}"; exit 2
    fi
    hc=0; docker exec waffled-api node dist/health-cli.js --pretty || hc=$?
    echo
    sc=0; status || sc=$?
    [ "$hc" -gt "$sc" ] && exit "$hc" || exit "$sc"
    ;;
  admin)
    # Operator/break-glass commands, run inside the api container (reaches the DB +
    # encryption key directly — no token/HTTP). Allocate a TTY when we have one so the
    # destructive-command confirmation prompts work.
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^waffled-api$'; then
      echo "${c_red}waffled-api is not running — start it with ./waffled up${c_reset}"; exit 2
    fi
    if [ -t 0 ]; then ti=(-it); else ti=(-i); fi
    docker exec "${ti[@]}" waffled-api node dist/admin.js "$@"
    ;;
  observability)
    ensure_env
    case "${1:-}" in
      up)
        set_env_var OTEL_EXPORTER_OTLP_ENDPOINT "http://lgtm:4318"
        echo "${c_dim}Starting local Grafana/OTEL stack + restarting api…${c_reset}"
        OTEL_EXPORTER_OTLP_ENDPOINT="http://lgtm:4318" "${DC[@]}" --profile observability up -d lgtm
        "${DC[@]}" up -d api
        gport="$(env_val GRAFANA_PORT)"; gport="${gport:-3001}"
        echo "${c_grn}Observability ON. Grafana → http://localhost:$gport (login admin / admin)${c_reset}"
        ;;
      down)
        set_env_var OTEL_EXPORTER_OTLP_ENDPOINT ""
        "${DC[@]}" --profile observability stop lgtm || true
        "${DC[@]}" up -d api
        echo "${c_grn}Observability OFF (api restarted without an OTLP endpoint; lgtm stopped).${c_reset}"
        ;;
      *) echo "usage: ./waffled observability up|down"; exit 1 ;;
    esac
    ;;
  web)
    # Vite dev server with HMR on :5173 (separate from the stack's :8080 build).
    ( cd "$ROOT/apps/web" && npm run dev ) ;;
  release)
    # Cut a release: bump EVERY place a version lives, in ONE commit, then tag it.
    # Run this LOCALLY (with your own git creds) — the pushed tag then triggers
    # publish-images.yml and the main push triggers Xcode Cloud, with no PAT/bot
    # token needed (a tag pushed by CI's GITHUB_TOKEN would NOT trigger either).
    #   ./waffled release 0.3.0
    #
    # Bumps: apps/api + apps/web package.json (+lockfiles), infra/compose/.env.example
    # WAFFLED_VERSION, and apps/ios/project.yml MARKETING_VERSION. The iOS BUILD number
    # (CURRENT_PROJECT_VERSION) is left alone — Xcode Cloud auto-increments that.
    # Also finalizes CHANGELOG.md: dates the [Unreleased] notes as this version, opens a
    # fresh [Unreleased], and adds the compare link — so the tag carries the release notes.
    ver="${1:-}"; ver="${ver#v}"
    if ! printf '%s' "$ver" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'; then
      echo "${c_red}usage: ./waffled release X.Y.Z${c_reset} (semver, no leading v)"; exit 1
    fi
    tag="v$ver"
    if [ -n "$(git -C "$ROOT" status --porcelain)" ]; then
      echo "${c_red}Working tree is dirty — commit or stash first so the release commit is clean.${c_reset}"; exit 1
    fi
    branch="$(git -C "$ROOT" symbolic-ref --short -q HEAD || echo '?')"
    if [ "$branch" != "main" ]; then
      printf "${c_ylw}You're on '%s', not main. Release from here anyway? [y/N] ${c_reset}" "$branch"
      read -r ans; case "$ans" in y|Y) ;; *) echo "Aborted."; exit 1 ;; esac
    fi
    if git -C "$ROOT" rev-parse -q --verify "refs/tags/$tag" >/dev/null; then
      echo "${c_red}Tag $tag already exists.${c_reset}"; exit 1
    fi
    # Review the notes that become this release's section. Convention: accrue them under
    # ## [Unreleased] as user-facing work lands (see CONTRIBUTING.md / CLAUDE.md). At least
    # ONE entry is REQUIRED — a release with no notes is refused; this is the last chance to
    # add or fix them ($EDITOR on request). Runs before any file change, so aborting here
    # leaves the tree untouched. Only 'a' aborts; anything unrecognized just re-prompts.
    CL="$ROOT/CHANGELOG.md"
    while :; do
      if [ ! -f "$CL" ] || ! grep -q '^## \[Unreleased\]' "$CL"; then
        printf "${c_ylw}No CHANGELOG [Unreleased] section — add one with your notes.${c_reset}  [${c_grn}e${c_reset}]dit   [${c_red}a${c_reset}]bort: "
        read -r ans; case "$ans" in a|A) echo "Aborted — nothing changed."; exit 1 ;; e|E) "${EDITOR:-vi}" "$CL" ;; esac
        continue
      fi
      body="$(awk '/^## \[Unreleased\]/{f=1;next} /^## \[/{f=0} f' "$CL")"
      n="$(printf '%s\n' "$body" | grep -cE '^[[:space:]]*-[[:space:]]' || true)"
      echo "${c_dim}—— CHANGELOG [Unreleased] → will become [$ver] ——${c_reset}"
      printf '%s\n' "$body"
      echo "${c_dim}————————————————————————————————————————————${c_reset}"
      if [ "$n" -eq 0 ]; then
        printf "${c_ylw}At least one entry is required to release.${c_reset}  [${c_grn}e${c_reset}]dit in \$EDITOR   [${c_red}a${c_reset}]bort: "
      else
        printf "Use these %s entr%s as the %s notes?  [${c_grn}Enter${c_reset}] yes   [e]dit   [${c_red}a${c_reset}]bort: " "$n" "$([ "$n" -eq 1 ] && echo y || echo ies)" "$tag"
      fi
      read -r ans
      case "$ans" in
        e|E) "${EDITOR:-vi}" "$CL" ;;
        a|A) echo "Aborted — nothing changed."; exit 1 ;;
        '') [ "$n" -gt 0 ] && break ;;
      esac
    done
    # Portable in-place edit (BSD/macOS + GNU sed): rewrite to a temp file, then move.
    bump_line() { local f="$1" expr="$2" tmp; tmp="$(mktemp)"; sed -E "$expr" "$f" > "$tmp" && mv "$tmp" "$f"; }
    echo "${c_dim}Bumping to ${ver}…${c_reset}"
    ( cd "$ROOT/apps/api" && npm version "$ver" --no-git-tag-version --allow-same-version >/dev/null )
    ( cd "$ROOT/apps/web" && npm version "$ver" --no-git-tag-version --allow-same-version >/dev/null )
    bump_line "$ROOT/infra/compose/.env.example" "s/^WAFFLED_VERSION=.*/WAFFLED_VERSION=$ver/"
    bump_line "$ROOT/apps/ios/project.yml" "s/^([[:space:]]*MARKETING_VERSION:[[:space:]]*).*/\\1\"$ver\"/"
    # Finalize the CHANGELOG so the release commit (and its tag) carries the notes:
    # date the [Unreleased] entries (already reviewed above) as this version, open a fresh
    # [Unreleased], and add the compare link. Repo URL + previous tag are derived (nothing
    # hard-coded). The review gate above already handled the missing/empty cases.
    if [ -f "$CL" ] && grep -q '^## \[Unreleased\]' "$CL"; then
      cl_date="$(date +%F)"
      prev="$(git -C "$ROOT" tag --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | grep -vx "$tag" | head -1)"
      tmp="$(mktemp)"
      awk -v ver="$ver" -v date="$cl_date" '
        !d && /^## \[Unreleased\]/ { print "## [Unreleased]"; print ""; print "### Added"; print ""; print "### Changed"; print ""; print "### Fixed"; print ""; print "## [" ver "] - " date; d=1; next }
        { print }' "$CL" > "$tmp" && mv "$tmp" "$CL"
      tmp="$(mktemp)"
      awk -v ver="$ver" -v prev="$prev" '
        /^\[Unreleased\]:/ { match($0, /https:\/\/[^ ]*\/compare\//); base=substr($0,RSTART,RLENGTH); print "[Unreleased]: " base "v" ver "...HEAD"; if (prev!="") print "[" ver "]: " base prev "...v" ver; next }
        { print }' "$CL" > "$tmp" && mv "$tmp" "$CL"
      echo "${c_dim}Finalized CHANGELOG → [$ver] - $cl_date${c_reset}"
    else
      echo "${c_ylw}⚠ No CHANGELOG [Unreleased] section — skipping changelog finalize.${c_reset}"
    fi
    git -C "$ROOT" --no-pager diff -- CHANGELOG.md apps/api/package.json apps/web/package.json \
      infra/compose/.env.example apps/ios/project.yml
    git -C "$ROOT" add -A
    git -C "$ROOT" commit -q -m "release: $tag

Bump api, web, compose (WAFFLED_VERSION), and iOS MARKETING_VERSION to $ver,
and finalize the CHANGELOG [$ver] section."
    git -C "$ROOT" tag -a "$tag" -m "Waffled $tag"
    echo "${c_grn}Committed + tagged $tag locally.${c_reset}"
    printf "Push '%s' + %s to origin now? [y/N] " "$branch" "$tag"
    read -r ans
    case "$ans" in
      y|Y)
        git -C "$ROOT" push origin "$branch"
        git -C "$ROOT" push origin "$tag"
        echo "${c_grn}Pushed. → Xcode Cloud builds iOS; publish-images.yml builds the server images.${c_reset}"
        ;;
      *) echo "Not pushed. When ready:  ${c_dim}git push origin $branch && git push origin $tag${c_reset}" ;;
    esac
    ;;
  help|-h|--help|*)
    awk 'NR>1 && /^#/ {sub(/^# ?/, ""); print; next} NR>1 {exit}' "$ROOT/waffled" ;;
esac
