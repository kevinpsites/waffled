# Site address comes from the environment so the same file works locally (":80")
# and on the tailnet/prod (a hostname → Caddy auto-provisions TLS).
{$CADDY_SITE_ADDRESS} {
	encode gzip
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(self), microphone=(self), geolocation=()"
		Strict-Transport-Security "max-age=31536000"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' {$POWERSYNC_PUBLIC_URL}; worker-src 'self' blob:; manifest-src 'self'; media-src 'self' blob: https:; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}

	# health check
	respond /healthz "ok" 200

	# API (chunk 2.2). Path is preserved upstream, so the api sees /api/*.
	handle /api/* {
		reverse_proxy api:3000 {
			# Replace caller-supplied forwarding chains with the address Caddy saw.
			header_up X-Forwarded-For {remote_host}
		}
	}
	# Google's browser callback is intentionally outside /api, but still enters
	# through the same public proxy instead of the loopback-only direct API port.
	handle /auth/google/* {
		reverse_proxy api:3000
	}

	# Uploaded media blobs. The api writes to the waffled_media volume (/data/media);
	# Caddy serves it read-only so the api stays out of the read path. handle_path
	# strips the /media prefix, so /media/<household>/<hex>.jpg → /data/media/<household>/<hex>.jpg.
	# Must precede the SPA catch-all below so these requests don't fall through to index.html.
	handle_path /media/* {
		root * /data/media
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	# the web SPA (built into this image from apps/web); SPA fallback to index.html
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

# PowerSync keeps a separate client-facing port, but Caddy owns the public socket
# so hostname mode gets TLS and the PowerSync service stays on the Compose network.
{$POWERSYNC_CADDY_ADDRESS} {
	encode gzip
	reverse_proxy powersync:8080
}
