# Site address comes from the environment so the same file works locally (":80")
# and on the tailnet/prod (a hostname → Caddy auto-provisions TLS).
{$CADDY_SITE_ADDRESS} {
	encode gzip

	# health check
	respond /healthz "ok" 200

	# API (chunk 2.2). Path is preserved upstream, so the api sees /api/*.
	handle /api/* {
		reverse_proxy api:3000
	}
	# PowerSync (chunk 4.1) is exposed directly on its own published port
	# (POWERSYNC_PORT, default 8090); clients get its URL from /api/powersync/token.
	# Front it with its own hostname when public ingress lands (M7).

	# the web SPA (built into this image from apps/web); SPA fallback to index.html
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
