# Copy to .env (gitignored):  just setup
# Local dev defaults are fine; fill real secrets per environment.

# ── Postgres ──
POSTGRES_USER=nook
POSTGRES_PASSWORD=local-dev-change-me
POSTGRES_DB=nook
POSTGRES_PORT=5432

# ── Ingress (Caddy) ──
# Local: leave CADDY_SITE_ADDRESS unset → plain HTTP on :80 (mapped to HTTP_PORT).
# Tailnet/prod: set to your MagicDNS hostname for auto-TLS, e.g. nook.your-tailnet.ts.net
# CADDY_SITE_ADDRESS=
HTTP_PORT=8080

# ── App config (used by api/worker in later chunks) ──
# NOOK_HOSTNAME=localhost
# TOKEN_ENCRYPTION_KEY=          # openssl rand -base64 32
# AUTH0_DOMAIN=
# AUTH0_AUDIENCE=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Backups → S3 (chunk 2.4; bucket + IAM come from Terraform) ──
# AWS_REGION=us-east-1
# BACKUP_S3_BUCKET=
# BACKUP_AWS_ACCESS_KEY_ID=
# BACKUP_AWS_SECRET_ACCESS_KEY=
