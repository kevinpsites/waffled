# Copy to .env (gitignored):  just setup
# Local dev defaults are fine; fill real secrets per environment.

# ── Postgres ──
POSTGRES_USER=nook
POSTGRES_PASSWORD=local-dev-change-me
POSTGRES_DB=nook
POSTGRES_PORT=5432

# ── Ingress (Caddy) ──
# Local: leave CADDY_SITE_ADDRESS unset → plain HTTP on :80 (mapped to HTTP_PORT).
# Tailnet/prod: set to your MagicDNS hostname for auto-TLS, e.g. nook.your-tailnet.ts.net
# CADDY_SITE_ADDRESS=
HTTP_PORT=8080

# ── App config (used by api/worker in later chunks) ──
# NOOK_HOSTNAME=localhost
# AUTH0_DOMAIN=
# AUTH0_AUDIENCE=

# ── Google Calendar OAuth (5.2) — independent of Auth0; powers "Connect your calendar" ──
# Encrypts the stored Google refresh token at rest (REQUIRED for the connect flow):
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI — must be registered on the OAuth client (Console → Credentials).
# Local dev points straight at the api (Caddy only proxies /api/*, not /auth/*):
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/auth/google/calendar/callback
# Scopes — full calendar read/write by default (calendarList + events + write-back):
GOOGLE_CALENDAR_SCOPES=openid email https://www.googleapis.com/auth/calendar

# ── Backups → S3 (chunk 2.4; bucket + IAM come from Terraform) ──
# AWS_REGION=us-east-1
# BACKUP_S3_BUCKET=
# BACKUP_AWS_ACCESS_KEY_ID=
# BACKUP_AWS_SECRET_ACCESS_KEY=

# --- AI capture bar (6.6) — set any subset; choose the active one in Settings ---
# Hosted Claude (most accurate). Key stays server-side, never sent to the kiosk.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Hosted OpenAI, or any OpenAI-compatible server via OPENAI_BASE_URL.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# Local Ollama (private — text stays on your network).
# Docker Desktop: http://host.docker.internal:11434 · Linux: http://172.17.0.1:11434
OLLAMA_HOST=
# OLLAMA_MODEL=llama3.1
