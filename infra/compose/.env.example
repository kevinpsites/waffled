# Waffled — environment for the Docker Compose stack.
# Copy to .env (gitignored), fill the required secrets, then `./waffled up`.
# (`./waffled up` auto-creates this file with freshly generated secrets if it's missing.)

# ── Required ────────────────────────────────────────────────────────────────
# Signs built-in + OIDC login sessions (HS256).  Generate: openssl rand -base64 48
LOCAL_JWT_SECRET=
# AES key encrypting secrets at rest (OIDC + Google client secret).
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ── Postgres ──
POSTGRES_USER=waffled
# This is interpolated into postgres:// URLs; use URL-safe characters.
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=change-me
POSTGRES_DB=waffled
POSTGRES_PORT=5432

# ── Ports / ingress (Caddy) ──
# Kiosk + web UI is served here; the API is reachable at /api behind it.
HTTP_PORT=8080
API_PORT=3000
POWERSYNC_PORT=8090
# URL clients use to reach PowerSync (returned by /api/powersync/token).
# POWERSYNC_PUBLIC_URL=http://localhost:8090
# Local: leave CADDY_SITE_ADDRESS unset → plain HTTP on :80 (mapped to HTTP_PORT).
# Prod/tailnet: set to your hostname for automatic TLS, e.g. waffled.example.com
# CADDY_SITE_ADDRESS=
# NOTE: the pantry barcode SCANNER needs a secure context (HTTPS, or localhost on
# the host machine). Over a plain http:// LAN address the browser blocks the camera;
# the scanner shows a warning and you can still type barcodes. Serve over HTTPS
# (a hostname above for auto-TLS, a Cloudflare tunnel, or a local CA) to use it on a
# tablet/remote kiosk — and PowerSync must then also be HTTPS (no mixed ws://).
# When NOT on localhost, set this so OIDC + calendar callback URLs are correct:
# PUBLIC_BASE_URL=https://waffled.example.com

# ── Sessions (optional; defaults shown) ──
# ACCESS_TOKEN_TTL_SECONDS=3600     # access token lifetime (1 hour)
# REFRESH_TOKEN_TTL_DAYS=60         # rotating refresh token lifetime
# AUTH_FORCE_PASSWORD=1             # break-glass: always show the password form

# ── Published images (pinned to this release) ──
# `./waffled up` PULLS these prebuilt GHCR images by default -- no local build needed.
# WAFFLED_VERSION is the single knob the release process bumps; the compose file resolves
# ghcr.io/kevinpsites/waffled-{api,caddy,backup}:${WAFFLED_VERSION} from it.
# Prefer to build from source instead? Run: ./waffled up --build
WAFFLED_VERSION=0.1.0
# Or override an individual image outright (fork / private registry / pinned digest);
# an explicit value here wins over WAFFLED_VERSION:
# WAFFLED_API_IMAGE=
# WAFFLED_CADDY_IMAGE=
# WAFFLED_BACKUP_IMAGE=

# ── AI capture bar (optional) — set any subset; pick the active one in Settings ──
# Hosted Claude (most accurate). Key stays server-side, never sent to the kiosk.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Hosted OpenAI, or any OpenAI-compatible server via OPENAI_BASE_URL.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# Local Ollama (private — text stays on your network).
# Docker Desktop: http://host.docker.internal:11434 · Linux: http://172.17.0.1:11434
OLLAMA_HOST=
# OLLAMA_MODEL=llama3.1

# ── Google Calendar 2-way sync (optional) ──
# Register a "Web application" OAuth client (Google Cloud Console → Credentials).
# The same client can also power OIDC sign-in (configure that in Settings).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI — must be registered on the OAuth client. Caddy only proxies /api/*,
# so the calendar callback points straight at the api. Localhost dev:
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/auth/google/calendar/callback
# Full calendar read/write (calendarList + events + write-back):
GOOGLE_CALENDAR_SCOPES=openid email https://www.googleapis.com/auth/calendar

# ── Media / blob uploads (optional; defaults shown) ──
# Uploaded images are written by the api to a local disk volume (waffled_media) and
# served directly by Caddy at MEDIA_BASE_URL, keeping the api out of the read path.
# STORAGE_DRIVER=local                # storage backend for uploaded blobs
# MEDIA_DIR=/data/media               # where the api writes blobs (the waffled_media volume)
# MEDIA_BASE_URL=/media               # public URL prefix Caddy serves blobs from

# ── Backups (on by default; local dumps need no config) ──
# The `backup` service dumps the DB nightly at BACKUP_TIME into the waffled_backups
# volume, pruned after BACKUP_RETENTION_DAYS. Run one now: `./waffled backup`.
# BACKUP_TIME=02:00                   # daily HH:MM (container timezone; set TZ to change)
# BACKUP_RETENTION_DAYS=14            # delete local dumps older than this
# BACKUP_ON_START=false              # also back up right after the container starts
# BACKUP_INCLUDE_MEDIA=false         # also archive uploaded media (waffled-media-*.tar.gz)
# BACKUP_HOST_PATH=/mnt/backups       # write dumps to a host folder instead of the volume
# BACKUP_ENABLED=false                # set if you REMOVE the backup service (stops health nagging)
# Optional offsite copy — push each dump to S3 / Backblaze B2 / Cloudflare R2 / MinIO:
# BACKUP_S3_BUCKET=s3://my-bucket/waffled
# BACKUP_S3_ENDPOINT=                 # set for B2/R2/MinIO (e.g. https://s3.us-west-000.backblazeb2.com); empty=AWS
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=

# ── Update notifier (optional) ──
# The admin System Health panel can check GitHub for a newer release. Set the repo to
# enable it; UPDATE_CHECK_ENABLED=false is a hard off-switch (no outbound call at all).
# UPDATE_CHECK_REPO=kevinpsites/waffled
# UPDATE_CHECK_ENABLED=true
